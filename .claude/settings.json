{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoCompactAt": 80,
  "permissions": {
    "allow": [
      "Bash(cargo fmt *)",
      "Bash(cargo clippy *)",
      "Bash(cargo check *)",
      "Bash(cargo test *)",
      "Bash(cargo build *)",
      "Bash(rustfmt *)"
    ]
  }
}
